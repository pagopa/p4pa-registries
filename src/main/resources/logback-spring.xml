<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <include resource="org/springframework/boot/logging/logback/defaults.xml"/>

    <springProperty scope="context" name="appName"
                    source="spring.application.name"/>

    <property name="CONSOLE_LOG_PATTERN"
              value="%d{yyyy-MM-dd HH:mm:ss.SSS} [${appName:-}] [%X{externalUserId:-}] [%X{traceId:-}] %-5level [%15.15t] [%-40.40logger{39}] - %msg%n"/>
    <property name="AUDIT_LOG_PATTERN"
              value="%msg"/>

    <appender name="STDOUT"
              class="ch.qos.logback.core.ConsoleAppender">
        <encoder
                class="ch.qos.logback.classic.encoder.PatternLayoutEncoder">
            <pattern>${CONSOLE_LOG_PATTERN}</pattern>
        </encoder>
    </appender>

    <appender name="ASYNC_STDOUT"
              class="ch.qos.logback.classic.AsyncAppender">
        <neverBlock>true</neverBlock>
        <queueSize>${ASYNC_LOG_QUEUE_SIZE:-500000}</queueSize>
        <discardingThreshold>0</discardingThreshold>
        <appender-ref ref="STDOUT"/>
    </appender>

    <condition class="ch.qos.logback.core.boolex.PropertyEqualityCondition">
        <key>ENABLE_AUDIT_APPENDER</key>
        <value>TRUE</value>
    </condition>
    <if>
        <then>
            <appender name="SYNC_AUDIT"
                      class="ch.qos.logback.core.ConsoleAppender">
                <encoder
                        class="ch.qos.logback.classic.encoder.PatternLayoutEncoder">
                    <pattern>%msg%n</pattern>
                </encoder>
            </appender>

            <appender name="AUDIT"
                      class="ch.qos.logback.classic.AsyncAppender">
                <neverBlock>true</neverBlock>
                <queueSize>${ASYNC_LOG_QUEUE_SIZE:-500000}</queueSize>
                <discardingThreshold>0</discardingThreshold>
                <appender-ref ref="SYNC_AUDIT"/>
            </appender>

            <condition class="ch.qos.logback.core.boolex.PropertyEqualityCondition">
                <key>ENABLE_KAFKA_AUDIT_APPENDER</key>
                <value>TRUE</value>
            </condition>
            <if>
                <then>
                  <appender name="SYNC_KAFKA_AUDIT" class="com.github.danielwegener.logback.kafka.KafkaAppender">
                    <encoder>
                      <pattern>%msg%n</pattern>
                    </encoder>
                    <topic>${KAFKA_AUDIT_TOPIC}</topic>
                    <producerConfig>bootstrap.servers=${KAFKA_BINDER_BROKER}</producerConfig>
                    <producerConfig>security.protocol=${KAFKA_CONFIG_SECURITY_PROTOCOL:-SASL_SSL}</producerConfig>
                    <producerConfig>sasl.mechanism=${KAFKA_CONFIG_SASL_MECHANISM:-PLAIN}</producerConfig>
                    <producerConfig>sasl.jaas.config=${KAFKA_AUDIT_PRODUCER_SASL_JAAS_CONFIG}</producerConfig>
                    <producerConfig>client.id=${appName:-}_audit</producerConfig>
                    <producerConfig>retries=${KAFKA_AUDIT_RETRIES:-3}</producerConfig>
                    <producerConfig>request.timeout.ms=${KAFKA_AUDIT_REQUEST_TIMEOUT_MS:-60000}</producerConfig>
                    <producerConfig>block.on.buffer.full=false</producerConfig>
                  </appender>

                  <appender name="KAFKA_AUDIT" class="ch.qos.logback.classic.AsyncAppender">
                    <neverBlock>true</neverBlock>
                    <queueSize>${ASYNC_LOG_QUEUE_SIZE:-500000}</queueSize>
                    <discardingThreshold>0</discardingThreshold>
                    <appender-ref ref="SYNC_KAFKA_AUDIT"/>
                  </appender>

                    <logger name="AUDIT" additivity="false">
                        <appender-ref ref="AUDIT"/>
                        <appender-ref ref="KAFKA_AUDIT"/>
                    </logger>
                </then>
                <else>
                    <logger name="AUDIT" additivity="false">
                        <appender-ref ref="AUDIT"/>
                    </logger>
                </else>
            </if>
        </then>
        <else>
            <logger name="AUDIT" additivity="false" level="OFF" />
        </else>
    </if>

    <root level="INFO">
        <appender-ref ref="ASYNC_STDOUT"/>
    </root>

    <appender name="KAFKA_CLIENT_LOG"
              class="ch.qos.logback.classic.AsyncAppender">
      <filter class="it.gov.pagopa.pu.common.kafka.config.KafkaLogFilter" />
      <appender-ref ref="ASYNC_STDOUT"/>
    </appender>

    <logger level="INFO" name="org.apache.kafka.clients.consumer" additivity="false">
        <appender-ref ref="KAFKA_CLIENT_LOG"/>
    </logger>

</configuration>
